generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String         @id @default(cuid())
  name              String?
  email             String         @unique
  password          String?
  role              Role           @default(EMPLOYEE)
  managerId         String?
  departmentId      String?
  shiftId           String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  autoPunchOutCount Int            @default(0)
  attendances       Attendance[]
  ledDepartment     Department?    @relation("DepartmentLeader")
  leaveBalances     LeaveBalance[]
  leaveRequests     LeaveRequest[]
  allowances        Allowance[]
  department        Department?    @relation("DepartmentMembers", fields: [departmentId], references: [id])
  manager           User?          @relation("ManagerToEmployee", fields: [managerId], references: [id], onUpdate: NoAction)
  employees         User[]         @relation("ManagerToEmployee")
  shift             Shift?         @relation(fields: [shiftId], references: [id])
}

model Department {
  id           String   @id @default(cuid())
  name         String   @unique
  teamLeaderId String?  @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  teamLeader   User?    @relation("DepartmentLeader", fields: [teamLeaderId], references: [id])
  members      User[]   @relation("DepartmentMembers")
}

model Shift {
  id        String   @id @default(cuid())
  name      String   @unique
  startTime String
  endTime   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]
}

model Attendance {
  id                String    @id @default(cuid())
  userId            String
  date              DateTime  @db.Date
  punchIn           DateTime
  punchOut          DateTime?
  isLate            Boolean   @default(false)
  isLateSpecialCase Boolean   @default(false)
  lat               Float?
  lng               Float?
  ipAddress         String?
  isOutsideOffice   Boolean   @default(false)
  isAutoPunchOut    Boolean   @default(false)
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model LeaveRequest {
  id          String        @id @default(cuid())
  userId      String
  startDate   DateTime
  endDate     DateTime
  duration    LeaveDuration
  category    LeaveCategory
  status      LeaveStatus   @default(PENDING)
  reason      String?
  managerNote String?
  startTime   String?
  endTime     String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  halfDayType String?
  leaveType   LeaveType?
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LeaveBalance {
  id                  String   @id @default(cuid())
  userId              String
  month               Int
  year                Int
  remainingFull       Float    @default(2.0)
  remainingShort      Int      @default(1)
  carriedForward      Float    @default(0.0)
  encashed            Float    @default(0.0)
  semiAnnualRemaining Int      @default(3)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  fullTaken           Float    @default(0.0)
  semiAnnualTaken     Float    @default(0.0)
  shortTaken          Int      @default(0)
  unpaidTaken         Float    @default(0.0)
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month, year])
}

model SystemConfig {
  id                           String   @id @default("GLOBAL_CONFIG")
  officeStartTime              String   @default("09:00")
  officeEndTime                String   @default("18:00")
  graceTimeMinutes             Int      @default(15)
  officeLat                    Float?
  officeLng                    Float?
  allowedRadiusMeters          Int      @default(500)
  updatedAt                    DateTime @updatedAt
  autoPunchOutDelayHours       Int      @default(2)
  autoPunchOutEnabled          Boolean  @default(true)
  autoPunchOutWarningThreshold Int      @default(3)
  firstHalfEndTime             String   @default("13:30")
  lateMarkAllowedCount         Int      @default(3)
  lateMarkEnabled              Boolean  @default(true)
  secondHalfStartTime          String   @default("13:30")
  semiAnnualCycleStartMonth    Int      @default(4)
  semiAnnualPolicyEnabled      Boolean  @default(true)
  specialCaseEnabled           Boolean  @default(true)
  specialCaseExtraMinutes      Int      @default(0)
}

enum Role {
  EMPLOYEE
  ACCOUNTANT
  ADMIN
  SYSTEM_ADMIN
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LeaveDuration {
  FULL
  HALF
  SHORT
}

enum LeaveCategory {
  MONTHLY_POLICY_1
  SEMI_ANNUAL_POLICY_2
  UNPAID
}

enum LeaveType {
  CASUAL
  MEDICAL
}

model Allowance {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromDate  DateTime    @db.Date
  toDate    DateTime    @db.Date
  location  String
  status    LeaveStatus @default(PENDING)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}
